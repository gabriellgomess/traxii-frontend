{
  "name": "traxii-frontends",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:gestor": "npm run dev -w apps/gestor",
    "dev:whitelabel": "npm run dev -w apps/whitelabel",
    "build": "npm run build -w apps/gestor && npm run build -w apps/whitelabel",
    "build:gestor": "npm run build -w apps/gestor",
    "build:whitelabel": "npm run build -w apps/whitelabel"
  }
}
